# Copy this file to .env and fill in your values.
# .env is loaded automatically by python-dotenv during local development.
# In production, set these as real environment variables — never commit .env.

# --- Flask ---
FLASK_DEBUG=false
PORT=5000

# --- PostgreSQL (optional) ---
# Leave these unset to use a local SQLite database instead (recommended for dev).
# DB_USER=your_postgres_user
# DB_PASSWORD=your_postgres_password
# DB_HOST=your_rds_or_postgres_host
# DB_PORT=5432
# DB_NAME=sentimentiq
